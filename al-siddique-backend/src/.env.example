# ══════════════════════════════════════════════════
#  APEX OS — Backend Environment Configuration
#  AL SIDDIQUE SCHOLARS PUBLIC SCHOOL (ASSPS)
#  Copy this file to .env and fill in real values
# ══════════════════════════════════════════════════

# Server
PORT=5000
NODE_ENV=production

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=apexos_db
DB_USER=apexos_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000

# JWT Authentication
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_MIN_32_CHARS
JWT_EXPIRES_IN=7d

# Redis Cache
REDIS_URL=redis://localhost:6379

# CORS — Frontend URLs (update after deployment)
FRONTEND_URL=https://yourdomain.com
SUPER_APP_URL=https://connect.yourdomain.com

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10mb
